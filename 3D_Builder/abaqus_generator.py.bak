import math
import os

def generate_abaqus_script(params, auto_run=False):
    """
    Generates an Abaqus Python script based on user parameters.
    """
    wall_height = params['wall_height']
    wall_width = params['wall_width']
    building_depth = params.get('building_depth', wall_width)
    wall_thickness = params['wall_thickness']
    has_window = params['has_window']
    window_width = params.get('window_width', 0)
    window_height = params.get('window_height', 0)
    sill_height = params.get('sill_height', 0)
    window_offset_x = params.get('window_offset_x', (wall_width - window_width)/2.0)
    wind_pressure = params['wind_pressure'] * 1000.0  # Convert kPa to Pa (N/m2)
    wind_direction = params['wind_direction'] 
    wind_duration = params.get('wind_duration', 0.1)
    max_num_inc = params.get('max_num_inc', 300)
    cdp_viscosity = params.get('cdp_viscosity', 0.05)
    def_scale_factor = params.get('def_scale_factor', 1.0)   
    apply_decay_field = params.get('apply_decay_field', False)
    has_roof_slab = params.get('has_roof_slab', True)
    model_type = params.get('model_type', '1. Smooth Wall (Macro-model)')
    brick_length = params.get('brick_length', 0.203)
    brick_height = params.get('brick_height', 0.057)
    brick_depth = params.get('brick_depth', 0.095)
    mortar_thickness = params.get('mortar_thickness', 0.010)
    wythes = params.get('wythes', 1)
    slab_thickness = params.get('slab_thickness', 0.15)
    mass_scaling = params.get('mass_scaling', 5e-5)
    num_cpus = params.get('num_cpus', 2)
    
    # Recalculate thickness for Meso to ensure perfection
    import math
    if "Meso-model" in model_type:
        wall_thickness = wythes * brick_depth + max(0, wythes - 1) * mortar_thickness
        # Trava Dimensional (Snap): Recalcula a largura externa para ser multiplo exato dos tijolos
        # Isso previne que o RightPillar seja gerado com milimetros a menos e corte a ponta da parede (Overlap fatal)
        eff_len = brick_length + mortar_thickness
        wall_width = math.ceil(wall_width / eff_len) * eff_len
        

    num_stories = params.get('num_stories', 1)
    
    winner_strategy = params.get('winner_strategy', 'None')
    winner_params = params.get('winner_params', {})
    joist_spacing_m = params.get('joist_spacing_in', 16.0) * 0.0254
    joist_count = int(wall_width / joist_spacing_m) if joist_spacing_m > 0 else 0
    
    bolt_dia_in = winner_params.get('bolt_dia', 0.625)
    bolt_dia_m = bolt_dia_in * 0.0254
    hw_height_in = winner_params.get('h', 20.0)
    hw_height_m = hw_height_in * 0.0254
    thk_in = winner_params.get('thk', 0.25)
    thk_m = thk_in * 0.0254
    
    joist_profile = params.get('joist_profile', "Nominal 2x10 (3.8 x 23.5 cm)")
    if "7.0 x 15.0" in joist_profile:
        joist_w, joist_h = 0.07, 0.15
    elif "8.9 x 23.5" in joist_profile:
        joist_w, joist_h = 0.089, 0.235
    elif "15 x 15" in joist_profile:
        joist_w, joist_h = 0.15, 0.15
    else:
        joist_w, joist_h = 0.038, 0.235

    script = f'''# -*- coding: utf-8 -*-
# Abaqus Python Script for Parametric Masonry Box (Explicit)
# Generated by Antigravity Masonry Simulator

from abaqus import *
from abaqusConstants import *
import __main__
import section
import regionToolset
import part
import material
import assembly
import step
from interaction import *
import load
import mesh
import optimization
import job
import sketch
import visualization
import connectorBehavior
import math

# Project Parameters
model_type = "{model_type}"
wall_height = {wall_height}
wall_width = {wall_width}
building_depth = {building_depth}
wall_thickness = {wall_thickness}
has_window = {has_window}
window_width = {window_width}
window_height = {window_height}
sill_height = {sill_height}
window_offset_x = {window_offset_x}
wind_pressure = {wind_pressure} * 1000 # Convert kPa to Pa
wind_duration = {wind_duration}
slab_thickness = {slab_thickness}
mass_scaling = {mass_scaling}
num_cpus = {num_cpus}
has_roof_slab = {has_roof_slab}

brick_length = {brick_length}
brick_height = {brick_height}
brick_depth = {brick_depth}
mortar_thickness = {mortar_thickness}
wythes = {wythes}

# 1. Model & Part Creation
if 'MasonryWallModel' in mdb.models.keys():
    myModel = mdb.models['MasonryWallModel']
    # Clear existing parts from this model to start fresh
    for partName in myModel.parts.keys():
        del myModel.parts[partName]
else:
    myModel = mdb.Model(name='MasonryWallModel')

# 2. Material Definition (Concrete Damage Plasticity)
myMaterial = myModel.Material(name='Masonry_CDP')
myMaterial.Density(table=((2000.0, ), ))
myMaterial.Elastic(table=((10e9, 0.2), ))
# Arsenals A & B: Dynamic Viscosity Parameter controlled via Dashboard to mathematically pad severe material snap-back fractures
myMaterial.ConcreteDamagedPlasticity(table=((38.0, 0.1, 1.16, 0.66, {cdp_viscosity}), ))
myMaterial.concreteDamagedPlasticity.ConcreteCompressionHardening(table=((15e6, 0.0), (20e6, 0.001), (15e6, 0.003), (8e6, 0.01)))
myMaterial.concreteDamagedPlasticity.ConcreteTensionStiffening(table=((1.5e6, 0.0), (1.2e6, 0.001), (0.9e6, 0.003), (0.6e6, 0.008), (0.3e6, 0.015), (0.1e6, 0.03), (0.01e6, 0.05)))
myMaterial.concreteDamagedPlasticity.ConcreteTensionDamage(table=((0.0, 0.0), (0.1, 0.001), (0.3, 0.003), (0.6, 0.008), (0.8, 0.015), (0.88, 0.03), (0.90, 0.05)))
myMaterial.concreteDamagedPlasticity.ConcreteCompressionDamage(table=((0.0, 0.0), (0.1, 0.003), (0.5, 0.01)))

myModel.HomogeneousSolidSection(name='WallSection', material='Masonry_CDP', thickness=None)

# Timber Deck and Joist Material (Wood)
timberMat = myModel.Material(name='Timber_Floor')
timberMat.Density(table=((500.0, ), ))
timberMat.Elastic(table=((10e9, 0.3), ))
myModel.HomogeneousSolidSection(name='SlabSection', material='Timber_Floor', thickness=None)

myAssembly = myModel.rootAssembly

# Global Slab Builder
def build_slab(name, y_elevation):
    mySlab = myModel.Part(name=name, dimensionality=THREE_D, type=DEFORMABLE_BODY)
    mySketch = myModel.ConstrainedSketch(name=name+'_Profile', sheetSize=20.0)
    mySketch.rectangle(point1=(0.0, 0.0), point2=(wall_width, slab_thickness))
    slab_extrusion_depth = building_depth

    mySlab.BaseSolidExtrude(sketch=mySketch, depth=slab_extrusion_depth)
    region = regionToolset.Region(cells=mySlab.cells)
    mySlab.SectionAssignment(region=region, sectionName='SlabSection')
    
    inst = myAssembly.Instance(name=name+'_Inst', part=mySlab, dependent=ON)
    inst.translate(vector=(0.0, y_elevation, 0.0))
    
    mySlab.seedPart(size=0.2, deviationFactor=0.1, minSizeFactor=0.1)
    if "Macro-model" in model_type:
        elemTypeSlab = mesh.ElemType(elemCode=C3D8, elemLibrary=STANDARD)
    else:
        # Prevent Element Library mixing by using Explicit elements for slabs in Meso-model
        elemTypeSlab = mesh.ElemType(elemCode=C3D8, elemLibrary=STANDARD)
        
    mySlab.setElementType(regions=(mySlab.cells,), elemTypes=(elemTypeSlab,))
    try: mySlab.generateMesh()
    except: pass



# Global Pillar Builder
def build_pillar(name, x_elevation):
    myPillar = myModel.Part(name=name, dimensionality=THREE_D, type=DEFORMABLE_BODY)
    mySketch = myModel.ConstrainedSketch(name=name+'_Profile', sheetSize=20.0)
    mySketch.rectangle(point1=(0.0, -slab_thickness), point2=(slab_thickness, wall_height+slab_thickness))
    
    myPillar.BaseSolidExtrude(sketch=mySketch, depth=building_depth+0.2)
    region = regionToolset.Region(cells=myPillar.cells)
    myPillar.SectionAssignment(region=region, sectionName='SlabSection')
    
    inst = myAssembly.Instance(name=name+'_Inst', part=myPillar, dependent=ON)
    # Z translation to cover slightly more than building depth for safety
    inst.translate(vector=(x_elevation, 0.0, -0.1))
    
    myPillar.seedPart(size=0.2, deviationFactor=0.1, minSizeFactor=0.1)
    if "Macro-model" in model_type:
        elemTypeSlab = mesh.ElemType(elemCode=C3D8, elemLibrary=STANDARD)
    else:
        elemTypeSlab = mesh.ElemType(elemCode=C3D8, elemLibrary=STANDARD)
        
    myPillar.setElementType(regions=(myPillar.cells,), elemTypes=(elemTypeSlab,))
    try: myPillar.generateMesh()
    except: pass

# Build Slabs and physical support Pillars only for Meso-model
if "Macro-model" not in model_type:
    # Floor slab holds the weight of the masonry blocks
    build_slab('FloorSlab', -slab_thickness)
    
    # Roof slab serves as the confining overhead beam
    if has_roof_slab:
        build_slab('RoofSlab', wall_height)
        
    # Vertical physical buttresses (acting as rigid contact boundaries)
    build_pillar('LeftPillar', -slab_thickness)
    build_pillar('RightPillar', wall_width)
        
if "Macro-model" in model_type:
    # Build Roof Slab to stiffen the top of the walls against wind
    if has_roof_slab:
        build_slab('RoofSlab', wall_height)
    

    # Multi-story geometry logic
    num_stories = {num_stories}
    total_height = {wall_height} * {num_stories}

    # Strategy: sketch floor plan in XY (width x depth), extrude in Z (height)
    # This creates a vertical pipe (4 walls, open top/bottom).
    # Then we rotate the instance in the assembly so height goes to Y axis.
    myBoxPart = myModel.Part(name='MasonryBox', dimensionality=THREE_D, type=DEFORMABLE_BODY)
    myBoxSketch = myModel.ConstrainedSketch(name='BoxFrameProfile', sheetSize=20.0)
    
    # Outer floor profile: width (Local X) x depth (Local Y)
    myBoxSketch.rectangle(point1=(0.0, 0.0), point2=(wall_width, building_depth))
    # Inner void
    myBoxSketch.rectangle(point1=(wall_thickness, wall_thickness),
                          point2=(wall_width - wall_thickness, building_depth - wall_thickness))
    
    # Extrude height in Local Z direction
    myBoxPart.BaseSolidExtrude(sketch=myBoxSketch, depth=total_height)

    
    # Feature window cut using deterministic Assembly Boolean Operations
    if has_window:
        myAssembly = myModel.rootAssembly
        # 1. Instantiate the temporary Box to be cut
        tempBoxInst = myAssembly.Instance(name='TempBox', part=myBoxPart, dependent=ON)
        
        # 2. Build the solid Punch Block
        myPunchPart = myModel.Part(name='WindowPunch', dimensionality=THREE_D, type=DEFORMABLE_BODY)
        myPunchSketch = myModel.ConstrainedSketch(name='PunchProfile', sheetSize=20.0)
        
        # The floor map of the unrotated box is drawn with X=width, Y=depth.
        # South wall footprint is the line at Y=0 stretching from X=0 to X=wall_width.
        # To punch through the face, our cut block must straddle Y=0.
        myPunchSketch.rectangle(point1=(window_offset_x, -wall_thickness*2.0), 
                                point2=(window_offset_x + window_width, wall_thickness*2.0))
        
        # Extrude vertically (Z axis) exact height of the window.
        myPunchPart.BaseSolidExtrude(sketch=myPunchSketch, depth=window_height)
        
        # 3. Instantiate Punch block into Assembly
        tempPunchInst = myAssembly.Instance(name='TempPunch', part=myPunchPart, dependent=ON)
        
        # 4. Lift the punch Block exactly to the Sill Height (Z = sill_height)
        tempPunchInst.translate(vector=(0.0, 0.0, sill_height))
        
        # 5. Execute absolute Assembly Boolean Cut
        final_instances = myAssembly.InstanceFromBooleanCut(name='MasonryBoxCut', 
            instanceToBeCut=tempBoxInst, 
            cuttingInstances=(tempPunchInst,), 
            originalInstances=DELETE)
            
        # 6. Re-assign the main Part Reference to the newly cut Boolean Solid directly from the returned object
        if isinstance(final_instances, (list, tuple)):
            myBoxPart = final_instances[0].part
            try: del myAssembly.instances[final_instances[0].name]
            except KeyError: pass
        else:
            myBoxPart = final_instances.part
            try: del myAssembly.instances[final_instances.name]
            except KeyError: pass
    
    myBoxPart.SectionAssignment(region=regionToolset.Region(cells=myBoxPart.cells), sectionName='WallSection')
    
    # Dynamic topology meshing: Solid walls can be swept with Hex bricks. 
    # Boolean-cut walls are generic volumes that require organic Tetrahedral mapping to mesh without partitioning scripts.
    if has_window:
        elemType = mesh.ElemType(elemCode=C3D10, elemLibrary=STANDARD)
        myBoxPart.setMeshControls(regions=myBoxPart.cells, elemShape=TET, technique=FREE)
    else:
        elemType = mesh.ElemType(elemCode=C3D8, elemLibrary=STANDARD)
        myBoxPart.setMeshControls(regions=myBoxPart.cells, technique=SWEEP)
    
    safe_mesh_size = min(0.18, wall_thickness)
    myBoxPart.seedPart(size=safe_mesh_size, deviationFactor=0.1, minSizeFactor=0.1)
    
    myBoxPart.setElementType(regions=(myBoxPart.cells,), elemTypes=(elemType,))
    try: myBoxPart.generateMesh()
    except: pass
    
    instBox = myAssembly.Instance(name='MasonryBox-1', part=myBoxPart, dependent=ON)
    
    # Assembly transformation:
    # Rotate -90 deg around X. Local Y(depth) becomes -Global Z. Local Z(height) becomes Global Y.
    instBox.rotateAboutAxis(axisPoint=(0.0, 0.0, 0.0), axisDirection=(1.0, 0.0, 0.0), angle=-90.0)
    # Translate to put in positive Z.
    instBox.translate(vector=(0.0, 0.0, building_depth))
    # Final state: X matches width. Y(up) matches height. Z matches depth. Base is at Y=0.

    # ==========================================
    # JOIST ARRAY AND STRATEGY LOGIC (MOVED UP)
    # ==========================================
    joist_count = {joist_count}
    joist_spacing_m = {joist_spacing_m}
    winner_strategy = '{winner_strategy}'
    hw_height_m = {hw_height_m}
    bolt_dia_m = {bolt_dia_m}
    thk_m = {thk_m}
    
    joist_w = {joist_w}
    joist_h = {joist_h}

    # 1. Fire-Cut Roof Joists builder
    myJoist = myModel.Part(name='RoofJoist', dimensionality=THREE_D, type=DEFORMABLE_BODY)
    myJSketch = myModel.ConstrainedSketch(name='JoistProfile', sheetSize=10.0)
    
    pocket_depth = wall_thickness * 0.66
    z_start = wall_thickness - pocket_depth
    z_end = building_depth - wall_thickness + pocket_depth
    
    p1 = (z_start, 0.0)
    p2 = (z_end, 0.0)
    p3 = (building_depth - wall_thickness, joist_h)
    p4 = (wall_thickness, joist_h)
    
    myJSketch.Line(point1=p1, point2=p2)
    myJSketch.Line(point1=p2, point2=p3)
    myJSketch.Line(point1=p3, point2=p4)
    myJSketch.Line(point1=p4, point2=p1)
    
    myJoist.BaseSolidExtrude(sketch=myJSketch, depth=joist_w)
    
    # CREATE OVERSIZED CUTTER TO AVOID NON-MANIFOLD SLIVERS (TET MESH CRASH)
    myCutter = myModel.Part(name='PocketCutter', dimensionality=THREE_D, type=DEFORMABLE_BODY)
    myCSketch = myModel.ConstrainedSketch(name='CutterProfile', sheetSize=10.0)
    
    # Pure rectangular block: no slant.
    # The max depth of the joist is at z_start and z_end.
    # So we use z_start as the back wall for the North side, and z_end for the South side.
    # We extend it into the central cavity (+0.1 and -0.1)
    
    c_p1 = (z_start, 0.0)
    c_p2 = (z_end, 0.0)
    c_p3 = (z_end, joist_h + 0.1)
    c_p4 = (z_start, joist_h + 0.1)
    
    myCSketch.Line(point1=c_p1, point2=c_p2)
    myCSketch.Line(point1=c_p2, point2=c_p3)
    myCSketch.Line(point1=c_p3, point2=c_p4)
    myCSketch.Line(point1=c_p4, point2=c_p1)
    # Oversize width to prevent side slivers
    myCutter.BaseSolidExtrude(sketch=myCSketch, depth=joist_w + 0.02)
    
    myJoist.seedPart(size=0.05, deviationFactor=0.1, minSizeFactor=0.1)

    # Force FREE TET to prevent zero-volume elements at the acute fire-cut corners
    try:
        myJoist.setMeshControls(regions=myJoist.cells, elemShape=TET, technique=FREE)
    except:
        pass

    elemTypeSlab = mesh.ElemType(elemCode=C3D8, elemLibrary=STANDARD)
    if "Macro-model" not in model_type:
        elemTypeSlab = mesh.ElemType(elemCode=C3D8R, elemLibrary=EXPLICIT, secondOrderAccuracy=OFF, hourglassControl=DEFAULT)

    elemTypeJoist = mesh.ElemType(elemCode=C3D10, elemLibrary=STANDARD)
    if "Macro-model" not in model_type:
        elemTypeJoist = mesh.ElemType(elemCode=C3D10M, elemLibrary=EXPLICIT)

    myJoist.setElementType(regions=(myJoist.cells,), elemTypes=(elemTypeJoist,))
    myJoist.SectionAssignment(region=regionToolset.Region(cells=myJoist.cells), sectionName='SlabSection')
    try: myJoist.generateMesh()
    except: pass

    # We will use duplicate parts for the boolean cut to avoid deleting our joists
    cutters = []
    
    # 2. Instance Joists and apply symmetric hardware
    for i in range(1, joist_count):
        x_pos = i * joist_spacing_m
        
        # Instantiate Joist
        j_inst = myAssembly.Instance(name='Joist_%d' % i, part=myJoist, dependent=ON)
        j_inst.rotateAboutAxis(axisPoint=(0,0,0), axisDirection=(0,1,0), angle=-90.0)
        j_inst.translate(vector=(x_pos, total_height - joist_h, 0.0))
        
        # Instantiate Cutter for pocket
        cutter_inst = myAssembly.Instance(name='Cutter_%d' % i, part=myCutter, dependent=ON)
        cutter_inst.rotateAboutAxis(axisPoint=(0,0,0), axisDirection=(0,1,0), angle=-90.0)
        cutter_inst.translate(vector=(x_pos + 0.01, total_height - joist_h, 0.0))
        cutters.append(cutter_inst)

        # 3. Apply Symmetric Strategy Hardware (ALWAYS MODEL FOR VISUALS)
        if True:
            if winner_strategy == 'G':
                h_part = myModel.Part(name='Holdown_%d' % i, dimensionality=THREE_D, type=DEFORMABLE_BODY)
                h_sketch = myModel.ConstrainedSketch(name='HSketch_%d' % i, sheetSize=2.0)
                h_sketch.rectangle(point1=(0.0, 0.0), point2=(thk_m, hw_height_m))
                h_part.BaseSolidExtrude(sketch=h_sketch, depth=thk_m)
                h_part.seedPart(size=0.02, deviationFactor=0.1, minSizeFactor=0.1)
                h_part.setElementType(regions=(h_part.cells,), elemTypes=(elemTypeSlab,))
                h_part.SectionAssignment(region=regionToolset.Region(cells=h_part.cells), sectionName='SlabSection')
                try: h_part.generateMesh()
                except: pass
                
                # North Wall (Z=0)
                h_inst_N = myAssembly.Instance(name='HW_G_N_%d' % i, part=h_part, dependent=ON)
                h_inst_N.translate(vector=(x_pos - thk_m, total_height - hw_height_m, wall_thickness))
                
                # South Wall (Z=building_depth)
                h_inst_S = myAssembly.Instance(name='HW_G_S_%d' % i, part=h_part, dependent=ON)
                h_inst_S.translate(vector=(x_pos - thk_m, total_height - hw_height_m, building_depth - wall_thickness - thk_m))

            elif winner_strategy == 'C':
                c_part = myModel.Part(name='FrictionPin_%d' % i, dimensionality=THREE_D, type=DEFORMABLE_BODY)
                c_sketch = myModel.ConstrainedSketch(name='CSketch_%d' % i, sheetSize=2.0)
                c_sketch.CircleByCenterPerimeter(center=(0.0, 0.0), point1=(bolt_dia_m/2.0, 0.0))
                c_part.BaseSolidExtrude(sketch=c_sketch, depth=hw_height_m)
                c_part.seedPart(size=0.02, deviationFactor=0.1, minSizeFactor=0.1)
                c_part.setElementType(regions=(c_part.cells,), elemTypes=(elemTypeSlab,))
                c_part.SectionAssignment(region=regionToolset.Region(cells=c_part.cells), sectionName='SlabSection')
                try: c_part.generateMesh()
                except: pass
                
                # North Wall (Z=0)
                c_inst_N = myAssembly.Instance(name='HW_C_N_%d' % i, part=c_part, dependent=ON)
                c_inst_N.rotateAboutAxis(axisPoint=(0,0,0), axisDirection=(1,0,0), angle=90.0)
                c_inst_N.translate(vector=(x_pos - joist_w/2.0, total_height, wall_thickness/2.0))
                
                # South Wall (Z=building_depth)
                c_inst_S = myAssembly.Instance(name='HW_C_S_%d' % i, part=c_part, dependent=ON)
                c_inst_S.rotateAboutAxis(axisPoint=(0,0,0), axisDirection=(1,0,0), angle=90.0)
                c_inst_S.translate(vector=(x_pos - joist_w/2.0, total_height, building_depth - wall_thickness/2.0))

    # 4. Create Joist Pockets via Boolean Cut 
    if "Macro-model" in model_type:
        pass
    else:
        try:
            new_inst = myAssembly.InstanceFromBooleanCut(name='MasonryBox_Cut', 
                instanceToBeCut=myAssembly.instances['MasonryBox-1'], 
                cuttingInstances=cutters, 
                originalInstances=DELETE)
            myAssembly.features.changeKey(fromName='MasonryBox_Cut-1', toName='MasonryBox-1')
        except Exception as e:
            pass
            
    # 5. Enable General Contact with Friction for realistic slide-out (MESO-MODEL ONLY)
    if "Macro-model" not in model_type:
        try:
            myModel.ContactProperty('JoistFriction')
            myModel.interactionProperties['JoistFriction'].TangentialBehavior(
                formulation=PENALTY, directionality=ISOTROPIC, slipRateDependency=OFF, 
                pressureDependency=OFF, temperatureDependency=OFF, dependencies=0, table=((0.4, ), ))
            myModel.interactionProperties['JoistFriction'].NormalBehavior(
                pressureOverclosure=HARD, allowSeparation=ON, constraintEnforcementMethod=DEFAULT)
            myModel.ContactExp(name='GeneralContact', createStepName='Initial')
            myModel.interactions['GeneralContact'].includedPairs.setValuesInStep(
                stepName='Initial', useAllstar=ON)
            myModel.interactions['GeneralContact'].contactPropertyAssignments.appendInStep(
                stepName='Initial', assignments=((GLOBAL, SELF, 'JoistFriction'), ))
        except Exception as e:
            pass

    # ==========================================
    # TIE CONSTRAINTS (MOVED DOWN)
    # ==========================================
    
    # 6. Tie joists to the wall for Macro-model so they don't fly away (causing singularities)
    if "Macro-model" in model_type:
        try:
            box_cells = myAssembly.instances['MasonryBox-1'].cells
            for i in range(1, joist_count):
                joist_inst = myAssembly.instances['Joist_%d' % i]
                joist_region = regionToolset.Region(cells=joist_inst.cells)
                wall_region = regionToolset.Region(cells=box_cells)
                # Removed JoistTie to allow fire-cut detachment baseline behavior
                
                # Tie Hardware (if it exists) to the wall
                if winner_strategy == 'G':
                    try:
                        hw_n_inst = myAssembly.instances['HW_G_N_%d' % i]
                        myModel.Tie(name='HW_G_N_Tie_%d' % i, main=wall_region, secondary=regionToolset.Region(cells=hw_n_inst.cells), positionToleranceMethod=SPECIFIED, positionTolerance=0.3, adjust=OFF)
                        hw_s_inst = myAssembly.instances['HW_G_S_%d' % i]
                        myModel.Tie(name='HW_G_S_Tie_%d' % i, main=wall_region, secondary=regionToolset.Region(cells=hw_s_inst.cells), positionToleranceMethod=SPECIFIED, positionTolerance=0.3, adjust=OFF)
                    except: pass
                elif winner_strategy == 'C':
                    try:
                        hw_n_inst = myAssembly.instances['HW_C_N_%d' % i]
                        myModel.Tie(name='HW_C_N_Tie_%d' % i, main=wall_region, secondary=regionToolset.Region(cells=hw_n_inst.cells), positionToleranceMethod=SPECIFIED, positionTolerance=0.3, adjust=OFF)
                        hw_s_inst = myAssembly.instances['HW_C_S_%d' % i]
                        myModel.Tie(name='HW_C_S_Tie_%d' % i, main=wall_region, secondary=regionToolset.Region(cells=hw_s_inst.cells), positionToleranceMethod=SPECIFIED, positionTolerance=0.3, adjust=OFF)
                    except: pass
        except Exception as e:
            pass
    # Tie constraint to securely clamp the Roof Slab to the tops of the walls without distorting nodes
    roof_bottom = myAssembly.instances['RoofSlab_Inst'].faces.getByBoundingBox(
        xMin=-0.1, yMin=total_height-1e-3, zMin=-0.1,
        xMax=wall_width+0.1, yMax=total_height+1e-3, zMax=building_depth+0.1)
    roof_region = regionToolset.Region(faces=roof_bottom)

            
    # 6. Tie constraint to securely clamp the Roof Slab exclusively to the top of the Joists
    if "Macro-model" in model_type:
        try:
            all_j_faces = None
            
            # Gather all top faces of the joists (User requested: only glue to joists, not masonry)
            if joist_count > 0:
                for i in range(1, joist_count):
                    try:
                        j_inst = myAssembly.instances['Joist_%d' % i]
                        j_faces = j_inst.faces.getByBoundingBox(xMin=-0.1, yMin=total_height-0.05, zMin=-0.1, xMax=wall_width+0.1, yMax=total_height+0.1, zMax=building_depth+0.1)
                        if all_j_faces is None:
                            all_j_faces = j_faces
                        else:
                            all_j_faces = all_j_faces + j_faces
                    except: pass
                    
            main_faces = None
            if all_j_faces is not None:
                main_faces = regionToolset.Region(faces=all_j_faces)
            
            # Fallback removed: Roof should never bond to the masonry walls directly.
            
            if main_faces is not None:
                # FIXED: build_slab uses name+'_Inst', so it's 'RoofSlab_Inst' NOT 'RoofSlab-1'
                roof_inst = myAssembly.instances['RoofSlab_Inst']
                roof_region = regionToolset.Region(cells=roof_inst.cells)
                
                myModel.Tie(name='RoofTie', main=main_faces, secondary=roof_region, positionToleranceMethod=SPECIFIED, positionTolerance=0.05, adjust=OFF)
        except Exception as e:
            pass

    if num_stories > 1:
        build_slab('IntermediateSlab', wall_height)
        # Intermediate Slab should also rest via General Contact, not rigidly tied to masonry.
        # InterTie removed to prevent gluing wood to masonry.

else:
    # --- MESO-MODEL (DISCRETE BRICKS) 3D BOX ---
    eff_length = brick_length + mortar_thickness
    eff_height = brick_height + mortar_thickness
    eff_depth = brick_depth + mortar_thickness
    
    myPart = myModel.Part(name='Brick', dimensionality=THREE_D, type=DEFORMABLE_BODY)
    mySketch = myModel.ConstrainedSketch(name='BrickProfile', sheetSize=2.0)
    mySketch.rectangle(point1=(0.0, 0.0), point2=(eff_length, eff_height))
    myPart.BaseSolidExtrude(sketch=mySketch, depth=eff_depth)
    myPart.SectionAssignment(region=regionToolset.Region(cells=myPart.cells), sectionName='WallSection')
    
    myHalfPart = myModel.Part(name='HalfBrick', dimensionality=THREE_D, type=DEFORMABLE_BODY)
    myHalfSketch = myModel.ConstrainedSketch(name='HalfBrickProfile', sheetSize=2.0)
    myHalfSketch.rectangle(point1=(0.0, 0.0), point2=(eff_length/2.0, eff_height))
    myHalfPart.BaseSolidExtrude(sketch=myHalfSketch, depth=eff_depth)
    myHalfPart.SectionAssignment(region=regionToolset.Region(cells=myHalfPart.cells), sectionName='WallSection')

    brick_idx = 1
    num_rows = int(math.ceil(wall_height / eff_height))
    
    for r in range(num_rows):
        y_pos = r * eff_height
        
        # Single Isolated South Wall (Optimized for Explicit Speed)
        # Buttressing lateral supports will be applied to the edge bricks in BCs.
        len_s = wall_width
        start_x_s = 0.0
        num_cols_s = int(math.ceil(len_s / eff_length)) + 1
        x_stagger_s = 0.0 if r % 2 == 0 else -eff_length/2.0
        
        for w in range(wythes):
            # Colocando a parede Sul na frente da caixa (Z = building_depth) em vez do fundo
            z_pos = building_depth - wall_thickness + w * eff_depth
            for c in range(num_cols_s):
                x_pos = start_x_s + x_stagger_s + c * eff_length
                b_len = eff_length
                is_half = False
                
                if x_pos < start_x_s - 1e-4:
                    x_pos = start_x_s
                    b_len = eff_length/2.0
                    is_half = True
                elif x_pos + eff_length > start_x_s + len_s + 1e-4:
                    if x_pos < start_x_s + len_s - 1e-4:
                        b_len = eff_length/2.0
                        is_half = True
                    else: continue
                    
                if has_window:
                    bc_x = x_pos + b_len / 2.0
                    bc_y = y_pos + brick_height / 2.0
                    if (window_offset_x <= bc_x <= window_offset_x + window_width) and (sill_height <= bc_y <= sill_height + window_height):
                        continue
                        
                part_to_use = myHalfPart if is_half else myPart
                inst = myAssembly.Instance(name='Brick_S_%d' % brick_idx, part=part_to_use, dependent=ON)
                inst.translate(vector=(x_pos, y_pos, z_pos))
                brick_idx += 1
    
    # 2.B Mesh Definitions for Discrete Bricks 
    # Revert to standard elements without deletion to avoid total wall vaporization under bending
    elemTypeExplicit = mesh.ElemType(elemCode=C3D8R, elemLibrary=EXPLICIT, secondOrderAccuracy=OFF, hourglassControl=DEFAULT)
    
    myPart.seedPart(size=0.04, deviationFactor=0.1, minSizeFactor=0.1)
    myPart.setElementType(regions=(myPart.cells,), elemTypes=(elemTypeExplicit,))
    try: myPart.generateMesh()
    except: pass
    
    myHalfPart.seedPart(size=0.04, deviationFactor=0.1, minSizeFactor=0.1)
    myHalfPart.setElementType(regions=(myHalfPart.cells,), elemTypes=(elemTypeExplicit,))
    try: myHalfPart.generateMesh()
    except: pass

# 3. Step Definitions
if "Macro-model" in model_type:
    myModel.StaticStep(name='GravityStep', previous='Initial', timePeriod=0.1, initialInc=0.01, minInc=1e-5, maxInc=0.1, maxNumInc={max_num_inc}, nlgeom=ON)
    myModel.Gravity(name='GravityLoad', createStepName='GravityStep', comp2=-9.81, distributionType=UNIFORM, field='')
    myModel.StaticStep(name='ApplyLoads', previous='GravityStep', timePeriod=wind_duration, initialInc=0.05, minInc=1e-8, maxInc=wind_duration/10.0, maxNumInc={max_num_inc}, stabilizationMethod=DISSIPATED_ENERGY_FRACTION, stabilizationMagnitude=0.0002, nlgeom=ON)
else:
    # Explicit Dynamics Motor for Discrete Bricks (Dynamic Chaos)
    # Abaqus tuple: (type, region, frequency, factor(0.0), dt({mass_scaling}), dtOption(BELOW_MIN),...)
    myModel.ExplicitDynamicsStep(name='GravityStep', previous='Initial', timePeriod=0.05, massScaling=((SEMI_AUTOMATIC, MODEL, AT_BEGINNING, 0.0, {mass_scaling}, BELOW_MIN, 0, 0, 0.0, 0.0, 0, None), ))
    myModel.Gravity(name='GravityLoad', createStepName='GravityStep', comp2=-9.81, distributionType=UNIFORM, field='')
    myModel.ExplicitDynamicsStep(name='ApplyLoads', previous='GravityStep', timePeriod=wind_duration, massScaling=((SEMI_AUTOMATIC, MODEL, AT_BEGINNING, 0.0, {mass_scaling}, BELOW_MIN, 0, 0, 0.0, 0.0, 0, None), ))
    
    # Global Dry Friction Contact Definition
    myModel.ContactProperty('MortarDryFriction')
    myModel.interactionProperties['MortarDryFriction'].TangentialBehavior(formulation=PENALTY, directionality=ISOTROPIC, slipRateDependency=OFF, pressureDependency=OFF, temperatureDependency=OFF, dependencies=0, table=((0.6, ), ), fraction=0.005)
    myModel.interactionProperties['MortarDryFriction'].NormalBehavior(pressureOverclosure=HARD, allowSeparation=ON)
    
    if "Macro-model" not in model_type:
        # ATUALIZACAO REVOLUCIONARIA POS-ESTUDO (Cohesive Surface Behavior para imitacao de argamassa 3D)
        myModel.interactionProperties['MortarDryFriction'].CohesiveBehavior()
        # Damage Initiation (MAX_STRESS/ENERGY): Tensao Normal (200 kPa), Cisalhamentos (400 kPa) | Energia de Fratura (10 J/m^2)
        myModel.interactionProperties['MortarDryFriction'].Damage(initTable=((200e3, 400e3, 400e3),), criterion=MAX_STRESS, useEvolution=ON, evolutionType=ENERGY, evolTable=((10.0, ), ))

    myModel.ContactExp(name='GlobalContact', createStepName='Initial')
    myModel.interactions['GlobalContact'].includedPairs.setValuesInStep(stepName='Initial', useAllstar=ON)
    myModel.interactions['GlobalContact'].contactPropertyAssignments.appendInStep(stepName='Initial', assignments=((GLOBAL, SELF, 'MortarDryFriction'), ))

    # Enable Element Deletion Tracking in Output ODB (Required for black holes)
    if 'F-Output-1' in myModel.fieldOutputRequests:
        myModel.fieldOutputRequests['F-Output-1'].setValues(variables=('S', 'PEEQ', 'U', 'RF', 'STATUS', 'DAMAGEC', 'DAMAGET'))

# 4. Boundary Conditions
all_instances = list(myAssembly.instances.values())

if "Macro-model" in model_type:
    # For Macro-model: EncastreBC at base of wall box (Y=0 face)
    # The absolute bulletproof way for boolean-cut dependent instances: 
    # Create the Set directly on the Part, then reference the inherited Set on the Instance.
    try:
        correct_part = myAssembly.instances['MasonryBox-1'].part
        # In the local part coordinate system:
        # X spans 0 to wall_width
        # Y spans 0 to building_depth
        # Z spans 0 to total_height (base is at Z=0)
        part_nodes = correct_part.nodes.getByBoundingBox(xMin=-0.2, yMin=-0.2, zMin=-0.2, xMax=wall_width+0.2, yMax=building_depth+0.2, zMax=0.05)
        
        if len(part_nodes) == 0:
            try: mdb.saveAs(pathName='MasonryWallModel_Crash.cae')
            except: pass
            
            all_n = correct_part.nodes
            if len(all_n) == 0:
                raise ValueError("Maaaaarcio, a Peca TEM ZERO NOS! SILENT MESH FAILURE CONFIRMADO!")
                
            min_y = min([n.coordinates[1] for n in all_n])
            max_y = max([n.coordinates[1] for n in all_n])
            min_z = min([n.coordinates[2] for n in all_n])
            max_z = max([n.coordinates[2] for n in all_n])
            
            raise ValueError("Maaaaarcio, NENHUM NO no Bounding Box! Mas a peca tem %d nos. Y vai de %.3f ate %.3f. Z vai de %.3f ate %.3f" % (len(all_n), min_y, max_y, min_z, max_z))
            
        correct_part.Set(name='BaseNodesSet', nodes=part_nodes)
        myAssembly.regenerate()
        
        myModel.EncastreBC(name='FixedBase', createStepName='Initial', 
                           region=myAssembly.instances['MasonryBox-1'].sets['BaseNodesSet'])
    except Exception as e:
        if "Maaaaarcio" in str(e):
            raise e
        try: mdb.saveAs(pathName='MasonryWallModel_Crash.cae')
        except: pass
        raise ValueError("Maaaaarcio, erro na criacao do Set da Part: " + str(e))
else:
    
    # Meso-Model Ghost Boundary Conditions (Frictionless Mathematical Sliders)
    y_floor_faces = []
    x_left_faces = []
    x_right_faces = []
    y_top_faces = []

    for inst in all_instances:
        # 1. Base Fixity (Floor)
        f_btm = inst.faces.getByBoundingBox(xMin=-0.1, yMin=-1e-3, zMin=-0.1, xMax=wall_width+0.1, yMax=1e-3, zMax=building_depth+0.1)
        if len(f_btm) > 0: y_floor_faces.append(f_btm[0:1])
        
        # O Lado Esquerdo, Lado Direito e o Teto nao recebem GhostPins cinematicos.
        # Eles se apoiarao exclusivamente nos Pilares/Lajes fisicos gerados.
        
        # Encastre Incondicional (Restricao Total) para Slabs e Pillars Fisicos
        if 'Slab' in inst.name or 'Pillar' in inst.name:
            reg = regionToolset.Region(cells=inst.cells)
            myModel.EncastreBC(name=inst.name+'_Fix', createStepName='Initial', region=reg)
            
    if y_floor_faces:
        floor_reg = y_floor_faces[0]
        for f in y_floor_faces[1:]: floor_reg += f
        myModel.EncastreBC(name='FloorSupport', createStepName='Initial', region=regionToolset.Region(faces=floor_reg))

# 5. Loads (Dynamic Selection Based on Wind Direction)
load_faces = None
direction_mode = "{wind_direction}"

if "Macro-model" in model_type:
    for inst in all_instances:
        f_to_add = []
        if direction_mode == "East Wall (Lateral)":
            f_east_ext = inst.faces.getByBoundingBox(
                xMin=wall_width-1e-3, yMin=-0.1, zMin=-0.1,
                xMax=wall_width+0.1, yMax=wall_height+0.1, zMax=building_depth+0.1)
            if len(f_east_ext) > 0: f_to_add.append(f_east_ext)
        elif direction_mode == "Internal Pressurization (Window Failure)":
            # Grab all 4 interior wall faces + the interior roof ceiling
            f_s_int = inst.faces.getByBoundingBox(xMin=-0.1, yMin=-0.1, zMin=building_depth-wall_thickness-1e-3, xMax=wall_width+0.1, yMax=wall_height+0.1, zMax=building_depth-wall_thickness+1e-3)
            f_n_int = inst.faces.getByBoundingBox(xMin=-0.1, yMin=-0.1, zMin=wall_thickness-1e-3, xMax=wall_width+0.1, yMax=wall_height+0.1, zMax=wall_thickness+1e-3)
            f_e_int = inst.faces.getByBoundingBox(xMin=wall_width-wall_thickness-1e-3, yMin=-0.1, zMin=-0.1, xMax=wall_width-wall_thickness+1e-3, yMax=wall_height+0.1, zMax=building_depth+0.1)
            f_w_int = inst.faces.getByBoundingBox(xMin=wall_thickness-1e-3, yMin=-0.1, zMin=-0.1, xMax=wall_thickness+1e-3, yMax=wall_height+0.1, zMax=building_depth+0.1)
            f_roof_int = inst.faces.getByBoundingBox(xMin=-0.1, yMin=wall_height-1e-3, zMin=-0.1, xMax=wall_width+0.1, yMax=wall_height+1e-3, zMax=building_depth+0.1)
            
            if len(f_s_int) > 0: f_to_add.append(f_s_int)
            if len(f_n_int) > 0: f_to_add.append(f_n_int)
            if len(f_e_int) > 0: f_to_add.append(f_e_int)
            if len(f_w_int) > 0: f_to_add.append(f_w_int)
            if len(f_roof_int) > 0: f_to_add.append(f_roof_int)
        else:
            # Default: South Wall (Head-on)
            f_south_ext = inst.faces.getByBoundingBox(
                xMin=-0.1, yMin=-0.1, zMin=building_depth-1e-3,
                xMax=wall_width+0.1, yMax=wall_height+0.1, zMax=building_depth+0.5)
            if len(f_south_ext) > 0: f_to_add.append(f_south_ext)
            
        for face_array in f_to_add:
            load_faces = face_array if load_faces is None else load_faces + face_array
else:
    # Meso-Model Accelerated Wind Loading
    for inst in all_instances:
        # Front outer face (Z = building_depth plane)
        f_south_ext = inst.faces.getByBoundingBox(
            xMin=-0.1, yMin=-0.1, zMin=building_depth-0.05, 
            xMax=wall_width+0.1, yMax=wall_height+0.1, zMax=building_depth+0.5)
        if len(f_south_ext) > 0: 
            load_faces = f_south_ext if load_faces is None else load_faces + f_south_ext

if load_faces:
    load_region = regionToolset.Region(side1Faces=load_faces)
    
    # Applying Pressure Load
    myModel.SmoothStepAmplitude(name='WindCurve', timeSpan=STEP, data=((0.0, 0.0), (wind_duration/4.0, 1.0), (wind_duration, 1.0)))
    
    if {apply_decay_field}:
        # Calculate dynamic window burst center for analytical decay
        wc_x = {window_offset_x} + {window_width}/2.0 if {window_width} > 0 else {wall_width}/2.0
        wc_y = {sill_height} + {window_height}/2.0 if {window_height} > 0 else {wall_height}/2.0
        
        # 3D Exponential Decay Field: P = P0 * exp(-0.4 * r)
        decay_expr = "exp(-0.4 * sqrt(pow(X - %f, 2) + pow(Y - %f, 2) + pow(Z - %f, 2)))" % (wc_x, wc_y, {building_depth})
        myModel.ExpressionField(name='DecayField', localCsys=None, description='Asymmetric Wind Decay from Burst Window', expression=decay_expr)
        
        # Map analytical field onto Pressure Load
        myModel.Pressure(name='WindLoad', createStepName='ApplyLoads', region=load_region, magnitude=wind_pressure, amplitude='WindCurve', distributionType=FIELD, field='DecayField')
    else:
        # Standard uniform projection. Implicit handles follower geometries automatically via nlgeom=ON building the tangent matrix.
        myModel.Pressure(name='WindLoad', createStepName='ApplyLoads', region=load_region, magnitude=wind_pressure, amplitude='WindCurve')

# 7. Job Creation & INP Injection
myJob = mdb.Job(name='MasonryWallJob', model='MasonryWallModel', 
                type=ANALYSIS, nodalOutputPrecision=SINGLE, 
                description='{model_type} dynamic run', numCpus=1, memory=90, memoryUnits=PERCENTAGE)

myJob.writeInput(consistencyChecking=OFF)

try:
    with open('MasonryWallJob.inp', 'rt') as f:
        lines = f.readlines()
        
    with open('MasonryWallJob.inp', 'wt') as f:
        injected_controls = False
        for line in lines:
            if line.strip().upper().startswith('*PART') and not injected_controls and "Macro-model" not in model_type:
                f.write('*Section Controls, name=DeleteControl, ELEMENT DELETION=YES, MAX DEGRADATION=0.99\\n')
                
            # INJECAO CIRURGICA: Element Deletion nos blocos Solidos baseados em Degradacao (SDEG)
            if line.strip().upper().startswith('*SOLID SECTION') and "Macro-model" not in model_type:
                if 'CONTROLS=' not in line.upper():
                    f.write(line.replace('\\n', '').strip() + ', controls=DeleteControl\\n')

            f.write(line)
            if '*OUTPUT, FIELD' in line.strip().upper():
                f.write('*Node Output\\nU, RF, CF\\n*Element Output, directions=YES\\nS, PE, PEEQ, PEMAG, LE, DAMAGEC, DAMAGET, SDEG, STATUS\\n*Contact Output\\nCSDMG\\n')
except:
    pass

myFinalJob = mdb.JobFromInputFile(name='MasonryWallJob_Final', inputFileName='MasonryWallJob.inp', 
                                  type=ANALYSIS, numCpus=1, memory=90, memoryUnits=PERCENTAGE)

# Salvar o banco de dados do modelo para acesso completo no Abaqus/CAE
mdb.saveAs(pathName='MasonryWallModel.cae')
print("Abaqus model script completed successfully.")
'''
    if auto_run:
        script += f'''
# --- AUTOMATED EXECUTION AND POST-PROCESSING ---
import visualization
import displayGroupOdbToolset as dgo
try:
    myFinalJob.submit()
    myFinalJob.waitForCompletion()
except Exception as e:
    print("Solver Error: " + str(e))

try:
    odbPath = 'MasonryWallJob_Final.odb'
    myOdb = visualization.openOdb(path=odbPath)

    session.viewports['Viewport: 1'].setValues(displayedObject=myOdb)
    session.viewports['Viewport: 1'].odbDisplay.display.setValues(plotState=(CONTOURS_ON_DEF,))
    session.printOptions.setValues(vpDecorations=OFF, compass=OFF)

    num_steps = len(myOdb.steps.keys())
    if num_steps > 0:
        last_step = myOdb.steps.values()[-1]
        if len(last_step.frames) > 0:
            session.viewports['Viewport: 1'].odbDisplay.setFrame(step=num_steps-1, frame=len(last_step.frames)-1)

    if {def_scale_factor} == 1.0:
        session.viewports['Viewport: 1'].odbDisplay.commonOptions.setValues(deformationScaling=UNIFORM, uniformScaleFactor=1.0)
    elif {def_scale_factor} == 0.0:
        session.viewports['Viewport: 1'].odbDisplay.display.setValues(plotState=(CONTOURS_ON_UNDEF,))
    else:
        session.viewports['Viewport: 1'].odbDisplay.commonOptions.setValues(deformationScaling=UNIFORM, uniformScaleFactor={def_scale_factor})

    try:
        session.viewports['Viewport: 1'].odbDisplay.setPrimaryVariable(variableLabel='S', outputPosition=INTEGRATION_POINT, refinement=(INVARIANT, 'Mises'))
        session.printToFile(fileName='mises_result', format=PNG, canvasObjects=(session.viewports['Viewport: 1'], ))
    except: pass
    try:
        session.viewports['Viewport: 1'].odbDisplay.setPrimaryVariable(variableLabel='DAMAGET', outputPosition=INTEGRATION_POINT)
        session.printToFile(fileName='damaget_result', format=PNG, canvasObjects=(session.viewports['Viewport: 1'], ))
    except: pass
    try:
        session.viewports['Viewport: 1'].odbDisplay.setPrimaryVariable(variableLabel='U', outputPosition=NODAL, refinement=(INVARIANT, 'Magnitude'))
        session.printToFile(fileName='u3_result', format=PNG, canvasObjects=(session.viewports['Viewport: 1'], ))
    except: pass
    try:
        session.viewports['Viewport: 1'].odbDisplay.setPrimaryVariable(variableLabel='CSDMG', outputPosition=INTEGRATION_POINT)
        session.printToFile(fileName='csdmg_result', format=PNG, canvasObjects=(session.viewports['Viewport: 1'], ))
    except: pass

except Exception as fatal_e:
    try:
        # If Abaqus completely aborted, we mask the actual .dat error log entirely as mises_result.png
        # This brilliantly forces the Streamlit UI to download it directly to the user's local PC via the ZIP
        import shutil
        import os
        if os.path.exists('MasonryWallJob_Final.dat'):
            shutil.copyfile('MasonryWallJob_Final.dat', 'mises_result.png')
        elif os.path.exists('masonry_slurm.out'):
            shutil.copyfile('masonry_slurm.out', 'mises_result.png')
    except: pass
'''
    return script
